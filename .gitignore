# Каталог сборки создаётся локально и не должен попадать в репозиторий.
build/

# Временные файлы и служебные артефакты не должны попадать в репозиторий.
tmp/

# Локальные артефакты IDE и редакторов.
.idea/
.vscode/
*.user
*.autosave

# Служебные файлы сборки CMake.
CMakeUserPresets.json
CMakeCache.txt
compile_commands.json

# Локальные журналы и служебные файлы запусков.
*.log

# Локальные автогенерированные карты кода не должны попадать в репозиторий.
docs/Map_Test/
